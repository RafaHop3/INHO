# INHO – Environment Variables (Backend)
# Copie este arquivo para .env e preencha os valores reais

# ── App ─────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=True

# ── Security (gere com: openssl rand -hex 32) ───────────────────
SECRET_KEY=CHANGE_ME_USE_OPENSSL_RAND_HEX_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database (PostgreSQL) ────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://inho_user:inho_pass@localhost:5432/inho_db

# ── CORS (adicione suas URLs de frontend) ───────────────────────
# ALLOWED_ORIGINS=["http://localhost:3000"]

# ── Rate Limiting ────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_MINUTE=10

# ── Keep-Alive (habilite apenas em produção Render) ─────────────
KEEP_ALIVE_ENABLED=False
SELF_URL=https://inho-api.onrender.com/health
